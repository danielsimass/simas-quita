{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "../../../",
    "outDir": "./dist",
    "module": "commonjs",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "importHelpers": true,
    "paths": {
      "@prisma/client": ["src/generated/prisma/client"],
      "@simas-quita/shared-financing-types": [
        "../../../libs/shared-financing-types/src/index.ts"
      ]
    }
  },
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "include": ["src/**/*.ts"]
}
