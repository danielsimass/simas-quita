{
  "name": "simas-quita",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "nx run-many -t serve --projects=controle-financiamentos-api,controle-financiamentos-web --parallel=2 --output-style=stream",
    "dev:api": "nx serve controle-financiamentos-api --configuration=development",
    "dev:web": "nx serve controle-financiamentos-web",
    "postinstall": "pnpm rebuild bcrypt 2>/dev/null || true",
    "build": "nx run-many -t build --all",
    "test": "nx run-many -t test --all",
    "lint": "nx run-many -t lint --all",
    "e2e": "nx e2e controle-financiamentos-e2e",
    "prisma:generate": "nx run controle-financiamentos-api:prisma-generate",
    "prisma:migrate": "cd apps/backends/controle-financiamentos-api && pnpm exec prisma migrate dev"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "@eslint/js": "^10.0.1",
