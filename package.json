    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@nx/eslint": "^22.7.5",
    "@nx/js": "^22.7.5",
    "@nx/nest": "^22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/playwright": "^22.7.5",
    "@nx/react": "^22.7.5",
    "@nx/vite": "^22.7.5",
    "@nx/vitest": "^22.7.5",
    "@nx/webpack": "^22.7.5",
    "@playwright/test": "^1.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.15.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/passport-jwt": "^4.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "nx": "^22.7.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
